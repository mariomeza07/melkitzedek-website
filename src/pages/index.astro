---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Welcome">

  <!-- Hero -->
  <section class="text-center py-16">
    <h1 class="text-4xl font-bold text-indigo-900 mb-4">
      Welcome to Grace Church
    </h1>
    <p class="text-lg text-gray-600 mb-8">
      A place of faith, hope, and community. Join us every Sunday at 10:00 AM.
    </p>
    <a href="/contact"
       class="bg-indigo-900 text-white px-6 py-3 rounded-lg hover:bg-indigo-700">
      Plan Your Visit
    </a>
  </section>

  <!-- Service times -->
  <section class="grid grid-cols-1 md:grid-cols-3 gap-6 mt-12">
    <div class="border rounded-lg p-6 text-center">
      <h3 class="font-bold text-indigo-900 mb-2">Sunday Service</h3>
      <p class="text-gray-600">10:00 AM – Main Worship</p>
    </div>
    <div class="border rounded-lg p-6 text-center">
      <h3 class="font-bold text-indigo-900 mb-2">Bible Study</h3>
      <p class="text-gray-600">Wednesday 7:00 PM</p>
    </div>
    <div class="border rounded-lg p-6 text-center">
      <h3 class="font-bold text-indigo-900 mb-2">Youth Group</h3>
      <p class="text-gray-600">Friday 6:00 PM</p>
    </div>
  </section>

</BaseLayout>