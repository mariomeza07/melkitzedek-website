---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const events = await getCollection('events');
events.sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
---

<BaseLayout title="Events">
  <h1 class="text-4xl font-bold text-church-navy mb-2">Upcoming Events</h1>
  <p class="text-gray-500 mb-10">Join us for our upcoming gatherings and activities.</p>

  <div class="grid gap-6">
    {events.map((event) => (
      <div class="border border-gray-200 rounded-xl p-6 bg-white shadow-sm flex gap-6 items-start">
        <div class="bg-church-navy text-white rounded-lg p-4 text-center min-w-[64px]">
          <p class="text-xs uppercase tracking-wide text-church-gold">
            {event.data.date.toLocaleDateString('en-US', { month: 'short' })}
          </p>
          <p class="text-2xl font-bold">
            {event.data.date.getDate()}
          </p>
        </div>
        <div>
          <h2 class="text-xl font-bold text-church-navy mb-1">{event.data.title}</h2>
          <p class="text-sm text-gray-500 mb-2">
            {event.data.time} · {event.data.location}
          </p>
          <p class="text-gray-700">{event.data.description}</p>
        </div>
      </div>
    ))}
  </div>
</BaseLayout>