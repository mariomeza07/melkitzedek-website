---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const sermons = await getCollection('sermons');
sermons.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Sermons">
  <h1 class="text-4xl font-bold text-church-navy mb-2">Sermons</h1>
  <p class="text-gray-500 mb-10">Listen to our latest messages from the Word.</p>

  <div class="grid gap-6">
    {sermons.map((sermon) => (
      <div class="border border-gray-200 rounded-xl p-6 bg-white shadow-sm">
        <p class="text-sm text-church-gold font-semibold mb-1">
          {sermon.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
        <h2 class="text-xl font-bold text-church-navy mb-1">{sermon.data.title}</h2>
        <p class="text-sm text-gray-500 mb-2">{sermon.data.pastor} · {sermon.data.scripture}</p>
        <p class="text-gray-700">{sermon.data.description}</p>
        {sermon.data.videoUrl && (
          <a href={sermon.data.videoUrl}
             class="inline-block mt-4 text-sm font-semibold text-church-gold hover:underline">
            ▶ Watch Sermon
          </a>
        )}
      </div>
    ))}
  </div>
</BaseLayout>